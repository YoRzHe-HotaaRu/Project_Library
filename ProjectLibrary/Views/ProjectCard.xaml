<UserControl x:Class="ProjectLibrary.Views.ProjectCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:ProjectLibrary.Converters"
             Width="300">
    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexBrush" />
    </UserControl.Resources>

    <Border Style="{StaticResource MangaCard}">
        <Border.InputBindings>
            <MouseBinding Gesture="LeftClick" Command="{Binding OpenCommand}" />
        </Border.InputBindings>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="160" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ======================= Thumbnail placeholder ======================= -->
            <Grid Grid.Row="0">
                <Rectangle Stretch="Fill">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding ThumbnailColorHex, Converter={StaticResource HexBrush}}" />
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Halftone overlay so the thumbnail has manga paper texture -->
                <Rectangle Fill="{StaticResource HalftonePatternFine}" Opacity="0.5" />
                <!-- Big letter centered as placeholder visual -->
                <Border Background="#33000000" Padding="20,0">
                    <TextBlock Text="{Binding ThumbnailLetter}"
                               FontFamily="{StaticResource MangaHeadlineFont}"
                               FontSize="100"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Favorite star (top-right, overlays thumbnail) -->
                <Button Command="{Binding ToggleFavoriteCommand}"
                        Width="36" Height="36"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Cursor="Hand"
                        ToolTip="Toggle favorite">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <materialDesign:PackIcon Kind="Star"
                                                         Width="28" Height="28"
                                                         VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Ruby}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ======================= Body ======================= -->
            <StackPanel Grid.Row="1" Margin="16,12">
                <TextBlock Text="{Binding Name}"
                           FontFamily="{StaticResource MangaHeadlineFont}"
                           FontSize="22"
                           Foreground="{StaticResource Ink}"
                           TextTrimming="CharacterEllipsis" />

                <!-- Tech badges (wrap) -->
                <ItemsControl ItemsSource="{Binding TechBadges}" Margin="0,8,0,6">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource TechBadge}"
                                    Background="{Binding ColorHex, Converter={StaticResource HexBrush}}">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontFamily="{StaticResource MangaBodyFont}"
                                           FontSize="11"
                                           FontStretch="Condensed"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding ForegroundHex, Converter={StaticResource HexBrush}}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding ShortPath}"
                           FontFamily="{StaticResource MangaMonoFont}"
                           FontSize="11"
                           Foreground="{StaticResource Muted}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4,0,8" />

                <DockPanel>
                    <TextBlock Text="{Binding RelativeLastActive}"
                               FontFamily="{StaticResource MangaBodyFont}"
                               FontSize="11"
                               Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right">
                        <Button Style="{StaticResource MangaSecondaryButton}"
                                Command="{Binding OpenInVsCodeCommand}"
                                Padding="6,4" Margin="4,0"
                                ToolTip="Open in VS Code">
                            <materialDesign:PackIcon Kind="MicrosoftVisualStudioCode" Width="16" Height="16" />
                        </Button>
                        <Button Style="{StaticResource MangaSecondaryButton}"
                                Command="{Binding OpenInTerminalCommand}"
                                Padding="6,4" Margin="4,0"
                                ToolTip="Open in Terminal">
                            <materialDesign:PackIcon Kind="Console" Width="16" Height="16" />
                        </Button>
                        <Button Style="{StaticResource MangaSecondaryButton}"
                                Command="{Binding OpenCommand}"
                                Padding="6,4" Margin="4,0"
                                ToolTip="Open in Explorer">
                            <materialDesign:PackIcon Kind="FolderOpen" Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
