<UserControl x:Class="ProjectLibrary.Views.FavoritesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:ProjectLibrary.Views"
             xmlns:conv="clr-namespace:ProjectLibrary.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource Paper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,16">
            <TextBlock Text="{Binding Kanji}" Style="{StaticResource KanjiAccent}" Margin="0,0,0,-6" />
            <TextBlock Text="{Binding Title}" Style="{StaticResource HeadlineText}" FontSize="64" />
            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" FontSize="14" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Search bar (hidden in empty state) -->
        <Border Grid.Row="1" Margin="40,0,40,16"
                HorizontalAlignment="Right"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <Border Width="320"
                    Background="{StaticResource PaperAlt}"
                    BorderBrush="{StaticResource Ink}" BorderThickness="2">
                <DockPanel>
                    <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20"
                                             Margin="10,0,0,0" VerticalAlignment="Center"
                                             Foreground="{StaticResource Muted}" />
                    <TextBox materialDesign:HintAssist.Hint="Search favorites..."
                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                             BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource Ink}"
                             CaretBrush="{StaticResource Ink}"
                             Padding="8,6" VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
            </Border>
        </Border>

        <!-- Cards grid -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto" Margin="40,0,40,24"
                      Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <ItemsControl ItemsSource="{Binding VisibleProjects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ProjectCard Margin="0,0,16,16" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{StaticResource Paper}"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="120" Height="120" CornerRadius="60"
                        Background="{StaticResource HalftonePattern}"
                        BorderBrush="{StaticResource Ink}" BorderThickness="3"
                        HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="StarOutline" Width="60" Height="60"
                                             Foreground="{StaticResource Ruby}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="NO FAVORITES YET" Style="{StaticResource SubheadingText}" FontSize="32"
                           HorizontalAlignment="Center" Margin="0,20,0,8" />
                <TextBlock Text="Tap the star on any project card to pin it here."
                           Style="{StaticResource MutedText}" FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
