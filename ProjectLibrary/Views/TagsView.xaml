<UserControl x:Class="ProjectLibrary.Views.TagsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ProjectLibrary.Views"
             xmlns:conv="clr-namespace:ProjectLibrary.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:HexToBrushConverter x:Key="HexBrush" />
    </UserControl.Resources>

    <Grid Background="{StaticResource Paper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,16">
            <TextBlock Text="{Binding Kanji}" Style="{StaticResource KanjiAccent}" Margin="0,0,0,-6" />
            <TextBlock Text="{Binding Title}" Style="{StaticResource HeadlineText}" FontSize="64" />
            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" FontSize="14" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Tag groups -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="40,0,40,24"
                      Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <ItemsControl ItemsSource="{Binding TagGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MangaPanel}" Margin="0,0,0,16" Padding="20">
                            <StackPanel>
                                <!-- Tag header (speech bubble + count) -->
                                <DockPanel Margin="0,0,0,14">
                                    <Border Style="{StaticResource SpeechBubbleTag}"
                                            Background="{Binding ColorHex, Converter={StaticResource HexBrush}}"
                                            BorderThickness="2" Padding="14,5">
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="{StaticResource MangaHeadlineFont}"
                                                   FontSize="18"
                                                   Foreground="{Binding ForegroundHex, Converter={StaticResource HexBrush}}" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center" Margin="10,0,0,0"
                                               FontFamily="{StaticResource MangaBodyFont}" FontSize="13"
                                               Foreground="{StaticResource Muted}">
                                        <Run Text="{Binding Count, Mode=OneWay}" />
                                        <Run Text=" project" /><Run Text="s" />
                                    </TextBlock>
                                </DockPanel>

                                <!-- Projects in this tag (horizontal scroll) -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding Projects}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <views:ProjectCard Margin="0,0,16,0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{StaticResource Paper}"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="120" Height="120" CornerRadius="60"
                        Background="{StaticResource HalftonePattern}"
                        BorderBrush="{StaticResource Ink}" BorderThickness="3"
                        HorizontalAlignment="Center">
                    <TextBlock Text="#"
                               FontFamily="{StaticResource MangaHeadlineFont}" FontSize="60"
                               Foreground="{StaticResource Ruby}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="NO TAGS YET" Style="{StaticResource SubheadingText}" FontSize="32"
                           HorizontalAlignment="Center" Margin="0,20,0,8" />
                <TextBlock Text="Add a project — tags appear here automatically based on detected tech."
                           Style="{StaticResource MutedText}" FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
