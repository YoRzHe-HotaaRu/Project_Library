<UserControl x:Class="ProjectLibrary.Views.AddProjectDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:ProjectLibrary.Converters"
             Width="520"
             HorizontalAlignment="Center" VerticalAlignment="Center">
    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexBrush" />
    </UserControl.Resources>

    <Border Style="{StaticResource MangaPanel}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="{StaticResource Ink}" Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="+ ADD NEW PROJECT"
                               FontFamily="{StaticResource MangaHeadlineFont}"
                               FontSize="22" Foreground="{StaticResource PaperAlt}" />
                    <Button Grid.Column="1" Content="X"
                            FontFamily="{StaticResource MangaHeadlineFont}"
                            FontSize="16"
                            Width="28" Height="28"
                            Background="Transparent" Foreground="{StaticResource PaperAlt}"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}" Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" Padding="24,8" VerticalScrollBarVisibility="Auto" MaxHeight="500">
                <StackPanel>

                    <TextBlock Text="PROJECT FOLDER" Style="{StaticResource FieldLabel}" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource MangaSecondaryButton}"
                                Content="BROWSE" Padding="14,6" Margin="8,0,0,0"
                                Command="{Binding BrowseCommand}" />
                        <TextBox Style="{StaticResource MangaTextBox}"
                                 Text="{Binding FolderPath, Mode=OneWay}"
                                 IsReadOnly="True" />
                    </DockPanel>

                    <TextBlock Text="PROJECT NAME" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource MangaTextBox}"
                             Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="DESCRIPTION (optional)" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource MangaTextBox}"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="64" VerticalContentAlignment="Top" />

                    <TextBlock Text="NOTES (private)" Style="{StaticResource FieldLabel}" />
                    <TextBox Style="{StaticResource MangaTextBox}"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="80" VerticalContentAlignment="Top" />

                    <TextBlock Text="TAGS" Style="{StaticResource FieldLabel}" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource MangaSecondaryButton}"
                                Content="+ ADD" Padding="14,6" Margin="8,0,0,0"
                                Command="{Binding AddTagCommand}" />
                        <TextBox Style="{StaticResource MangaTextBox}"
                                 Text="{Binding TagInput, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="TagInput_KeyDown" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding CustomTags}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SpeechBubbleTag}">
                                    <TextBlock Text="{Binding}" Style="{StaticResource BodyText}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="AUTO-DETECTED TECH" Style="{StaticResource FieldLabel}" />
                    <ItemsControl ItemsSource="{Binding DetectedTech}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TechBadge}"
                                        Background="{Binding ColorHex, Converter={StaticResource HexBrush}}">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontFamily="{StaticResource MangaBodyFont}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding ForegroundHex, Converter={StaticResource HexBrush}}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0"
                               FontFamily="{StaticResource MangaBodyFont}" FontSize="12"
                               Foreground="{StaticResource Ruby}" />

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource PaperAlt}"
                    BorderBrush="{StaticResource Ink}" BorderThickness="0,3,0,0"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource MangaSecondaryButton}"
                            Content="CANCEL" Padding="20,8" Margin="0,0,8,0"
                            Command="{Binding CancelCommand}" />
                    <Button Style="{StaticResource MangaPrimaryButton}"
                            Content="SAVE PROJECT" Padding="20,8"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
