<UserControl x:Class="ProjectLibrary.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:ProjectLibrary.Views"
             xmlns:conv="clr-namespace:ProjectLibrary.Converters">
    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexBrush" />
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <ScrollViewer Background="{StaticResource Paper}" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== Page header ===== -->
            <StackPanel Grid.Row="0" Margin="40,32,40,20">
                <TextBlock Text="{Binding Kanji}" Style="{StaticResource KanjiAccent}" Margin="0,0,0,-6" />
                <TextBlock Text="{Binding Title}" Style="{StaticResource HeadlineText}" FontSize="64" />
                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" FontSize="14" Margin="0,2,0,0" />
            </StackPanel>

            <!-- ===== Hero carousel (only when projects exist) ===== -->
            <Border x:Name="HeroCard"
                    Grid.Row="1"
                    Margin="40,0,40,24"
                    Style="{StaticResource MangaPanel}"
                    Height="400"
                    MouseEnter="HeroCard_MouseEnter"
                    MouseLeave="HeroCard_MouseLeave"
                    Visibility="{Binding HasProjects, Converter={StaticResource BoolVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="4*" />
                    </Grid.ColumnDefinitions>

                    <!-- Thumbnail area -->
                    <Grid Grid.Column="0" Margin="24" ClipToBounds="True">
                        <Rectangle Stretch="Fill">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding CurrentSlide.ThumbnailColorHex, Converter={StaticResource HexBrush}}" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Fill="{StaticResource HalftonePatternFine}" Opacity="0.4" />
                        <Border Background="#33000000">
                            <TextBlock Text="{Binding CurrentSlide.ThumbnailLetter}"
                                       FontFamily="{StaticResource MangaHeadlineFont}"
                                       FontSize="240"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Project info -->
                    <StackPanel Grid.Column="1" Margin="32,28" VerticalAlignment="Center">
                        <TextBlock Text="FEATURED"
                                   FontFamily="{StaticResource MangaHeadlineFont}"
                                   FontSize="14"
                                   Foreground="{StaticResource Ruby}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding CurrentSlide.Name}"
                                   FontFamily="{StaticResource MangaHeadlineFont}"
                                   FontSize="52"
                                   Foreground="{StaticResource Ink}"
                                   TextTrimming="CharacterEllipsis" />

                        <!-- Tech badges -->
                        <ItemsControl ItemsSource="{Binding CurrentSlide.TechBadges}" Margin="0,14,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TechBadge}"
                                            Background="{Binding ColorHex, Converter={StaticResource HexBrush}}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontFamily="{StaticResource MangaBodyFont}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding ForegroundHex, Converter={StaticResource HexBrush}}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding CurrentSlide.ShortPath}"
                                   FontFamily="{StaticResource MangaMonoFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource Muted}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,4,0,2" />

                        <TextBlock FontFamily="{StaticResource MangaBodyFont}" FontSize="13"
                                   Foreground="{StaticResource InkLight}" Margin="0,0,0,18">
                            <Run Text="Last active " />
                            <Run Text="{Binding CurrentSlide.RelativeLastActive, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>

                        <!-- Quick-launch buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource MangaSecondaryButton}"
                                    Command="{Binding CurrentSlide.OpenInVsCodeCommand}"
                                    Padding="16,8" Margin="0,0,8,0"
                                    ToolTip="Open in VS Code">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="MicrosoftVisualStudioCode" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="VS CODE" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MangaSecondaryButton}"
                                    Command="{Binding CurrentSlide.OpenInTerminalCommand}"
                                    Padding="16,8" Margin="0,0,8,0"
                                    ToolTip="Open in Terminal">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Console" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="TERMINAL" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MangaPrimaryButton}"
                                    Command="{Binding CurrentSlide.OpenCommand}"
                                    Padding="16,8"
                                    ToolTip="Open in File Explorer">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text="EXPLORER" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Prev / Next arrows -->
                    <Button HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Width="36" Height="48"
                            Command="{Binding GoToPreviousSlideCommand}"
                            Background="{StaticResource Ink}" Foreground="{StaticResource PaperAlt}"
                            BorderThickness="0" Cursor="Hand" Opacity="0.85"
                            Content="‹" FontSize="28" FontFamily="{StaticResource MangaHeadlineFont}"
                            ToolTip="Previous project" />
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Width="36" Height="48"
                            Command="{Binding GoToNextSlideCommand}"
                            Background="{StaticResource Ink}" Foreground="{StaticResource PaperAlt}"
                            BorderThickness="0" Cursor="Hand" Opacity="0.85"
                            Content="›" FontSize="28" FontFamily="{StaticResource MangaHeadlineFont}"
                            ToolTip="Next project" />

                    <!-- Slide status (bottom center) -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,14"
                            Background="{StaticResource Ink}"
                            Padding="12,4">
                        <TextBlock Text="{Binding SlideStatus}"
                                   FontFamily="{StaticResource MangaMonoFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource PaperAlt}" />
                    </Border>
                </Grid>
            </Border>

            <!-- ===== Empty-state hero (when no projects) ===== -->
            <Border Grid.Row="1"
                    Margin="40,0,40,24"
                    Style="{StaticResource MangaPanel}"
                    Height="400"
                    Visibility="{Binding HasNoProjects, Converter={StaticResource BoolVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="BookPlusMultiple" Width="80" Height="80"
                                             Foreground="{StaticResource Ruby}"
                                             HorizontalAlignment="Center" />
                    <TextBlock Text="NO PROJECTS YET" Style="{StaticResource SubheadingText}" FontSize="28"
                               HorizontalAlignment="Center" Margin="0,16,0,4" />
                    <TextBlock Text="Click + ADD PROJECT in the top bar to feature your first project here."
                               Style="{StaticResource MutedText}" FontSize="13"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ===== Recently active strip ===== -->
            <StackPanel Grid.Row="2" Margin="40,0,40,32"
                        Visibility="{Binding HasProjects, Converter={StaticResource BoolVis}}">
                <TextBlock Text="RECENTLY ACTIVE" Style="{StaticResource SubheadingText}" FontSize="22" Margin="0,0,0,12" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding RecentlyActive}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:ProjectCard Margin="0,0,16,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
