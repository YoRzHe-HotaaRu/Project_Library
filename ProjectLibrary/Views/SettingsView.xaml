<UserControl x:Class="ProjectLibrary.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer Background="{StaticResource Paper}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,32">

            <!-- Page header -->
            <TextBlock Text="{Binding Kanji}" Style="{StaticResource KanjiAccent}" Margin="0,0,0,-6" />
            <TextBlock Text="{Binding Title}" Style="{StaticResource HeadlineText}" FontSize="64" />
            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" FontSize="14" Margin="0,2,0,24" />

            <!-- Application info panel -->
            <Border Style="{StaticResource MangaPanel}" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="InformationOutline" Width="24" Height="24"
                                                 Foreground="{StaticResource Ruby}" VerticalAlignment="Center" />
                        <TextBlock Text="APPLICATION" Style="{StaticResource SubheadingText}" FontSize="20"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}" Margin="0,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Project Library" Style="{StaticResource BodyText}" Margin="0,4" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Version" Style="{StaticResource FieldLabel}" Margin="0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AppVersion}" Style="{StaticResource MonoText}" Margin="0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tech stack" Style="{StaticResource FieldLabel}" Margin="0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource BodyText}" Margin="0,4">
                            WPF • C# • MaterialDesign • SQLite
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Library stats panel -->
            <Border Style="{StaticResource MangaPanel}" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="Database" Width="24" Height="24"
                                                 Foreground="{StaticResource Ruby}" VerticalAlignment="Center" />
                        <TextBlock Text="LIBRARY" Style="{StaticResource SubheadingText}" FontSize="20"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Total projects" Style="{StaticResource FieldLabel}" Margin="0,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProjectCount}" Style="{StaticResource BodyText}" Margin="0,4" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Favorites" Style="{StaticResource FieldLabel}" Margin="0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FavoriteCount}" Style="{StaticResource BodyText}" Margin="0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Database size" Style="{StaticResource FieldLabel}" Margin="0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DbSize}" Style="{StaticResource MonoText}" Margin="0,4" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Database path" Style="{StaticResource FieldLabel}" Margin="0,4" />
                        <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,4">
                            <Button DockPanel.Dock="Right" Style="{StaticResource MangaSecondaryButton}"
                                    Padding="10,4" Margin="8,0,0,0"
                                    Command="{Binding OpenDbFolderCommand}"
                                    Content="OPEN" />
                            <TextBlock Text="{Binding DbPath}" Style="{StaticResource MonoText}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        </DockPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About panel -->
            <Border Style="{StaticResource MangaPanel}" Padding="24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="BookOpenVariant" Width="24" Height="24"
                                                 Foreground="{StaticResource Ruby}" VerticalAlignment="Center" />
                        <TextBlock Text="ABOUT" Style="{StaticResource SubheadingText}" FontSize="20"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource BodyText}" TextWrapping="Wrap">
                        Project Library is a manga-styled Steam-like library for organizing your development project folders.
                        Add a folder once; the app auto-detects the tech stack and keeps the project one click away from
                        VS Code, Windows Terminal, and File Explorer.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
