<UserControl x:Class="ProjectLibrary.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:ProjectLibrary.Views"
             xmlns:conv="clr-namespace:ProjectLibrary.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource Paper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Margin="40,32,40,16">
            <TextBlock Text="{Binding Kanji}" Style="{StaticResource KanjiAccent}" Margin="0,0,0,-6" />
            <TextBlock Text="{Binding Title}" Style="{StaticResource HeadlineText}" FontSize="64" />
            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource MutedText}" FontSize="14" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Margin="40,0,40,16"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <DockPanel>

                <Border DockPanel.Dock="Right" Width="280" HorizontalAlignment="Right"
                        Background="{StaticResource PaperAlt}"
                        BorderBrush="{StaticResource Ink}" BorderThickness="2" Margin="16,0,0,0">
                    <DockPanel>
                        <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20"
                                                 Margin="10,0,0,0" VerticalAlignment="Center"
                                                 Foreground="{StaticResource Muted}" />
                        <TextBox materialDesign:HintAssist.Hint="Search by name, path, tech..."
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="{StaticResource Ink}"
                                 CaretBrush="{StaticResource Ink}"
                                 Padding="8,6" VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </Border>

                <ToggleButton DockPanel.Dock="Right" Margin="12,0,0,0"
                              IsChecked="{Binding ShowFavoritesOnly}"
                              Style="{StaticResource MangaToggleButton}"
                              Cursor="Hand"
                              ToolTip="Show only favorites">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Star" Width="16" Height="16" VerticalAlignment="Center" />
                        <TextBlock Text="FAVORITES" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SORT BY" Style="{StaticResource FieldLabel}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSort}"
                              MinWidth="140"
                              Background="{StaticResource PaperAlt}"
                              Foreground="{StaticResource Ink}"
                              BorderBrush="{StaticResource Ink}" BorderThickness="2"
                              Padding="8,4" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Project grid (visible when there are projects) -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto" Margin="40,0,40,24"
                      Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <ItemsControl ItemsSource="{Binding VisibleProjects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ProjectCard Margin="0,0,16,16" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state (visible when there are no projects at all) -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{StaticResource Paper}"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="120" Height="120" CornerRadius="60"
                        Background="{StaticResource HalftonePattern}"
                        BorderBrush="{StaticResource Ink}" BorderThickness="3"
                        HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="FolderPlus" Width="60" Height="60"
                                             Foreground="{StaticResource Ruby}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="NO PROJECTS YET" Style="{StaticResource SubheadingText}" FontSize="32"
                           HorizontalAlignment="Center" Margin="0,20,0,8" />
                <TextBlock Text="Click + ADD PROJECT in the top bar to track your first folder."
                           Style="{StaticResource MutedText}" FontSize="14"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
