<Window x:Class="ProjectLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ProjectLibrary.ViewModels"
        xmlns:views="clr-namespace:ProjectLibrary.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Project Library"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Paper}">

    <materialDesign:DialogHost Identifier="MainDialogHost"
                                IsOpen="{Binding IsAddDialogOpen}"
                                CloseOnClickAway="True"
                                DialogBackground="{StaticResource Paper}">
        <materialDesign:DialogHost.DialogContent>
            <views:AddProjectDialog DataContext="{Binding AddProject}" />
        </materialDesign:DialogHost.DialogContent>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ====================== Top Bar ====================== -->
            <Border Grid.Row="0" Style="{StaticResource TopBar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo + brand -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <materialDesign:PackIcon Kind="BookOpenVariant" Width="32" Height="32"
                                                 Foreground="{StaticResource Ruby}" VerticalAlignment="Center" />
                        <TextBlock Text="PROJECT LIBRARY"
                                   FontFamily="{StaticResource MangaHeadlineFont}"
                                   FontSize="28" VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="{StaticResource Ink}" />
                    </StackPanel>

                    <!-- Search -->
                    <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="{StaticResource PaperAlt}"
                            BorderBrush="{StaticResource Ink}" BorderThickness="2" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Magnify" Width="20" Height="20"
                                                     Margin="10,0,0,0" VerticalAlignment="Center"
                                                     Foreground="{StaticResource Muted}" />
                            <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Search projects..."
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     BorderBrush="Transparent" BorderThickness="0"
                                     CaretBrush="{StaticResource Ink}"
                                     Foreground="{StaticResource Ink}"
                                     VerticalContentAlignment="Center"
                                     Width="320" Padding="8,6"
                                     Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <!-- Add Project button -->
                    <Button Grid.Column="2" Style="{StaticResource MangaPrimaryButton}"
                            Content="+ ADD PROJECT" Margin="20,0"
                            Command="{Binding OpenAddDialogCommand}"
                            ToolTip="Add a new project folder to your library" />
                </Grid>
            </Border>

            <!-- ====================== Body: Content + Sidebar ====================== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>

                <!-- Content area: renders the current page view model -->
                <ContentControl Grid.Column="0"
                                Content="{Binding CurrentPage, NotifyOnTargetUpdated=True}"
                                RenderTransformOrigin="0,0">
                    <ContentControl.RenderTransform>
                        <TranslateTransform />
                    </ContentControl.RenderTransform>
                    <ContentControl.Triggers>
                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                     From="24" To="0" Duration="0:0:0.28">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1" Duration="0:0:0.28" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ContentControl.Triggers>
                </ContentControl>

                <!-- Sidebar -->
                <Border Grid.Column="1" Style="{StaticResource Sidebar}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <RadioButton Style="{StaticResource SidebarNavItem}"
                                     GroupName="Nav"
                                     IsChecked="True"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="home"
                                     ToolTip="Home">
                            <materialDesign:PackIcon Kind="Home" Width="26" Height="26" />
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarNavItem}"
                                     GroupName="Nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="library"
                                     ToolTip="Library">
                            <materialDesign:PackIcon Kind="FolderMultiple" Width="26" Height="26" />
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarNavItem}"
                                     GroupName="Nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="favorites"
                                     ToolTip="Favorites">
                            <materialDesign:PackIcon Kind="Star" Width="26" Height="26" />
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarNavItem}"
                                     GroupName="Nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="tags"
                                     ToolTip="Tags">
                            <materialDesign:PackIcon Kind="TagMultiple" Width="26" Height="26" />
                        </RadioButton>

                        <RadioButton Style="{StaticResource SidebarNavItem}"
                                     GroupName="Nav"
                                     Command="{Binding NavigateToCommand}"
                                     CommandParameter="settings"
                                     ToolTip="Settings">
                            <materialDesign:PackIcon Kind="Cog" Width="26" Height="26" />
                        </RadioButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
