<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- ============================== Effects ============================== -->

    <!-- Solid offset "ink drop" shadow — no blur, like a manga panel drop -->
    <DropShadowEffect x:Key="InkShadow"
                      Color="{StaticResource InkColor}"
                      ShadowDepth="4"
                      BlurRadius="0"
                      Direction="315"
                      Opacity="0.9" />

    <!-- Softer variant for hovers / popovers -->
    <DropShadowEffect x:Key="InkShadowSoft"
                      Color="{StaticResource InkColor}"
                      ShadowDepth="3"
                      BlurRadius="0"
                      Direction="315"
                      Opacity="0.35" />

    <!-- ============================== Panels / Cards ============================== -->

    <!-- Generic manga panel — ink border + solid offset shadow -->
    <Style x:Key="MangaPanel" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Background" Value="{StaticResource PaperAlt}" />
        <Setter Property="Effect" Value="{StaticResource InkShadow}" />
    </Style>

    <!-- Project card with hover state (ink -> ruby border, thickens on hover) -->
    <Style x:Key="MangaCard" TargetType="Border">
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource InkColor}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Background" Value="{StaticResource PaperAlt}" />
        <Setter Property="Effect" Value="{StaticResource InkShadow}" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard Storyboard="{StaticResource CardHoverEnter}" />
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard Storyboard="{StaticResource CardHoverLeave}" />
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- ============================== Top bar / Sidebar ============================== -->

    <Style x:Key="TopBar" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PaperAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="0,0,0,3" />
    </Style>

    <Style x:Key="Sidebar" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HalftonePattern}" />
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
    </Style>

    <!-- ============================== Buttons ============================== -->

    <!-- Primary ruby CTA button with ink border -->
    <Style x:Key="MangaPrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource MangaHeadlineFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource PaperAlt}" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource RubyColor}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Padding" Value="20,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Effect" Value="{StaticResource InkShadow}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource RubyDarkColor}" />
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                    </Setter.Value>
                </Setter>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Secondary (paper) button — ink border on paper background -->
    <Style x:Key="MangaSecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource MangaHeadlineFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="Background" Value="{StaticResource PaperAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Padding" Value="20,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Halftone}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Manga-styled toggle button (for filter chips, the favorites toggle, etc.) -->
    <Style x:Key="MangaToggleButton" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource MangaHeadlineFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="Background" Value="{StaticResource PaperAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Halftone}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{StaticResource RubyLight}" />
                <Setter Property="Foreground" Value="{StaticResource Ink}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar nav item button -->
    <Style x:Key="SidebarNavItem" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Margin" Value="0,6" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="NavBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="0"
                            Width="56" Height="56">
                        <Grid>
                            <!-- Ruby accent bar shown when checked -->
                            <Border x:Name="AccentBar"
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Stretch"
                                    Background="{StaticResource Ruby}"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Halftone}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="AccentBar" Property="Opacity" Value="1" />
                            <Setter Property="Foreground" Value="{StaticResource Ruby}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================== Tags / Badges ============================== -->

    <!-- Speech-bubble tag badge -->
    <Style x:Key="SpeechBubbleTag" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource RubyLight}" />
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <!-- Tech-stack pill (ink border, fills with tech color via Background binding) -->
    <Style x:Key="TechBadge" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="Margin" Value="0,0,4,0" />
    </Style>

    <!-- ============================== Form fields ============================== -->

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MangaHeadlineFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="Margin" Value="0,12,0,4" />
    </Style>

    <Style x:Key="MangaTextBox" TargetType="TextBox">
        <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Background" Value="{StaticResource PaperAlt}" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontFamily" Value="{StaticResource MangaBodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CaretBrush" Value="{StaticResource Ink}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Ruby}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
