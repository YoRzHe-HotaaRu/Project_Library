<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Fonts are bundled under Resources/Fonts and marked as Resource in the csproj.
        WPF resolves them via a pack URI pointing at the folder + the font's internal name (#Name).
        System fallbacks (Arial Narrow, Segoe UI, Consolas) are appended so the UI still renders
        if a bundled font is missing or fails to load.
    -->

    <!-- Bebas Neue — single-weight display face used for headlines + subheadings -->
    <FontFamily x:Key="MangaHeadlineFont">pack://application:,,,/Resources/Fonts/#Bebas Neue, Arial Narrow, Bahnschrift</FontFamily>

    <!-- Inter — UI body text -->
    <FontFamily x:Key="MangaBodyFont">pack://application:,,,/Resources/Fonts/#Inter, Segoe UI, Arial</FontFamily>

    <!-- Noto Serif JP — decorative kanji accents -->
    <FontFamily x:Key="MangaAccentFont">pack://application:,,,/Resources/Fonts/#Noto Serif JP, Yu Mincho, MS Mincho</FontFamily>

    <!-- JetBrains Mono — paths + tech details -->
    <FontFamily x:Key="MangaMonoFont">pack://application:,,,/Resources/Fonts/#JetBrains Mono, Consolas, Cascadia Mono</FontFamily>

    <!-- Default app font (bind to FrameworkElement.FontFamily globally via App style) -->
    <FontFamily x:Key="DefaultFont">pack://application:,,,/Resources/Fonts/#Inter, Segoe UI, Arial</FontFamily>

    <!-- ===== Text styles ===== -->
    <Style x:Key="HeadlineText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MangaHeadlineFont}" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="FontSize" Value="36" />
    </Style>

    <Style x:Key="SubheadingText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MangaHeadlineFont}" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="FontSize" Value="20" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MangaBodyFont}" />
        <Setter Property="Foreground" Value="{StaticResource Ink}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MangaBodyFont}" />
        <Setter Property="Foreground" Value="{StaticResource Muted}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MangaMonoFont}" />
        <Setter Property="Foreground" Value="{StaticResource InkLight}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="KanjiAccent" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MangaAccentFont}" />
        <Setter Property="Foreground" Value="{StaticResource Ruby}" />
        <Setter Property="FontSize" Value="22" />
    </Style>

</ResourceDictionary>
