<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Ruby Palette ===== -->
    <Color x:Key="RubyColor">#E0115F</Color>
    <Color x:Key="RubyDarkColor">#9B1B30</Color>
    <Color x:Key="RubyLightColor">#F5A0B8</Color>

    <!-- ===== Manga Ink / Paper ===== -->
    <Color x:Key="InkColor">#1A1A1A</Color>
    <Color x:Key="InkLightColor">#3A3A3A</Color>
    <Color x:Key="PaperColor">#F8F5F0</Color>
    <Color x:Key="PaperAltColor">#FFFFFF</Color>
    <Color x:Key="HalftoneColor">#E8E4E0</Color>
    <Color x:Key="MutedColor">#7A7A7A</Color>

    <!-- ===== Brushes (primary usage) ===== -->
    <SolidColorBrush x:Key="Ruby" Color="{StaticResource RubyColor}" />
    <SolidColorBrush x:Key="RubyDark" Color="{StaticResource RubyDarkColor}" />
    <SolidColorBrush x:Key="RubyLight" Color="{StaticResource RubyLightColor}" />

    <SolidColorBrush x:Key="Ink" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="InkLight" Color="{StaticResource InkLightColor}" />
    <SolidColorBrush x:Key="Paper" Color="{StaticResource PaperColor}" />
    <SolidColorBrush x:Key="PaperAlt" Color="{StaticResource PaperAltColor}" />
    <SolidColorBrush x:Key="Halftone" Color="{StaticResource HalftoneColor}" />
    <SolidColorBrush x:Key="Muted" Color="{StaticResource MutedColor}" />

    <!-- ===== MaterialDesign color overrides (so Material components pick up ruby) ===== -->
    <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="{StaticResource RubyLightColor}" />
    <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="{StaticResource RubyColor}" />
    <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="{StaticResource PaperAltColor}" />
    <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="{StaticResource RubyDarkColor}" />
    <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush" Color="{StaticResource PaperAltColor}" />

    <SolidColorBrush x:Key="SecondaryHueLightBrush" Color="{StaticResource HalftoneColor}" />
    <SolidColorBrush x:Key="SecondaryHueLightForegroundBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="SecondaryHueMidBrush" Color="{StaticResource InkLightColor}" />
    <SolidColorBrush x:Key="SecondaryHueMidForegroundBrush" Color="{StaticResource PaperAltColor}" />
    <SolidColorBrush x:Key="SecondaryHueDarkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="SecondaryHueDarkForegroundBrush" Color="{StaticResource PaperAltColor}" />

</ResourceDictionary>
